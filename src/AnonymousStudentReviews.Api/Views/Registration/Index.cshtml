@model AnonymousStudentReviews.Api.Features.Registration.RegistrationRequest

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <title>Register</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f5f5f5;
        }

        .register-container {
            background-color: #fff;
            padding: 30px 40px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            width: 350px;
        }

        h2 {
            text-align: center;
            margin-bottom: 20px;
            color: #333;
        }

        form div {
            margin-bottom: 15px;
        }

        label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
            font-size: 0.9em;
        }

        input[type="text"], input[type="email"], input[type="password"] {
            width: 100%;
            padding: 8px 10px;
            border: 1px solid #ccc;
            border-radius: 4px;
            font-size: 0.9em;
        }

        button {
            width: 100%;
            padding: 10px;
            background-color: #007acc;
            color: #fff;
            font-size: 1em;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }

        button:hover {
            background-color: #005f99;
        }

        .validation-message {
            color: red;
            font-size: 0.8em;
        }
    </style>
</head>
<body>
<div class="register-container">
    <h2>Register</h2>

    <form asp-action="Index" asp-controller="Registration" method="post">
        @Html.AntiForgeryToken()
        <div>
            <label asp-for="Email">Email</label>
            <input asp-for="Email" type="email" required/>
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Password">Password</label>
            <input asp-for="Password" type="password" required/>
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="ConfirmPassword">Confirm password</label>
            <input asp-for="ConfirmPassword" type="password" required/>
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <button type="submit">Register</button>
    </form>
</div>

@section Scripts
{
    <script src="~/js/validation.js"></script>
}

</body>
</html>
