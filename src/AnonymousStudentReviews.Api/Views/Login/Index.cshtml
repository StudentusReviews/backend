@model AnonymousStudentReviews.Api.Features.Login.LoginRequest

@section HeadScripts
{
    <link rel="stylesheet" href="~/css/styles-output.css" asp-append-version="true">
}

<div
    class="min-h-screen flex flex-col bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 transition-colors duration-200">
    <main class="grow flex flex-col items-center justify-center px-4 py-16">

        <div
            class="w-full max-w-md rounded-2xl bg-gray-100 dark:bg-gray-800 p-8 shadow-xl transition-colors duration-200">
            <h1 class="text-2xl font-semibold text-center mb-6 transition">
                Увійти
            </h1>

            <form asp-controller="Login" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]"
                  class="space-y-4">
                @Html.AntiForgeryToken()

                @if (ViewData["ErrorName"] is not null)
                {
                    <div
                        class="rounded-xl p-4 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 flex items-start space-x-3">
                        <svg class="w-5 h-5 text-red-600 dark:text-red-400 mt-0.5 shrink-0" fill="none"
                             stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <div class="text-sm text-red-800 dark:text-red-200">
                            <h3 class="font-medium">@ViewData["ErrorName"]</h3>
                            <p class="mt-1 text-red-700 dark:text-red-300">@ViewData["ErrorDescription"]</p>
                        </div>
                    </div>
                }

                <div>
                    <label asp-for="Email" for="email"
                           class="block mb-2 font-semibold transition-colors duration-200 text-gray-600 dark:text-gray-400">
                        Електронна пошта
                    </label>
                    <input
                        asp-for="Email"
                        id="email"
                        type="email"
                        placeholder="your.email@example.ua"
                        class="w-full px-5 py-2.5 pr-12 rounded-2xl transition-colors duration-200 focus:outline-none text-base shadow-sm
                            bg-gray-50 dark:bg-gray-800 border border-gray-300 hover:border-gray-400 dark:border-gray-600 focus:ring-1 focus:ring-blue-500"/>
                    <span id="emailError" class="hidden text-sm text-red-600 dark:text-red-400 mt-1 block"></span>
                    <span asp-validation-for="Email" class="text-sm text-red-600 dark:text-red-400 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Password" for="password"
                           class="block mb-2 font-semibold transition-colors duration-200 text-gray-600 dark:text-gray-400">
                        Пароль
                    </label>
                    <input
                        asp-for="Password"
                        id="password"
                        type="password"
                        placeholder="Пароль"
                        class="w-full px-5 py-2.5 pr-12 rounded-2xl transition-colors duration-200 focus:outline-none text-base shadow-sm 
                            bg-gray-50 dark:bg-gray-800 border border-gray-300 hover:border-gray-400 dark:border-gray-600 focus:ring-1 focus:ring-blue-500"/>
                    <span id="passwordError" class="hidden text-sm text-red-600 dark:text-red-400 mt-1 block"></span>
                    <span asp-validation-for="Password"
                          class="text-sm text-red-600 dark:text-red-400 mt-1 block"></span>
                </div>

                <div class="flex items-center">
                    <input asp-for="RememberMe" id="remember-me" type="checkbox"
                           class="form-checkbox w-4 h-4 text-blue-600 bg-gray-50 border-gray-300 rounded focus:ring-blue-500 dark:bg-gray-800 dark:border-gray-600">
                    <label asp-for="RememberMe" for="remember-me"
                           class="ml-2 text-sm font-medium text-gray-500 dark:text-gray-400">Запам’ятати
                        мене</label>
                </div>

                <div class="text-center text-gray-900 dark:text-white">
                    <button
                        type="submit"
                        class="w-full mt-4 mb-4 py-3 rounded-2xl disabled:opacity-60 disabled:cursor-not-allowed bg-blue-500 hover:bg-blue-700 text-white transition">
                        Увійти
                    </button>
                    <p>Ще не маєте акаунта? <a href="/sign-up" class="text-blue-500 font-bold hover:underline">Зареєструватися</a>
                    </p>
                </div>
            </form>
        </div>
    </main>

</div>

@section BodyScripts
{
    <script src="~/js/loginFormValidation.js" asp-append-version="true"></script>
}

