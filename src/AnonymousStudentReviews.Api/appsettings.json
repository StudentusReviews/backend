{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "DatabaseConnections": {
    "MainDatabase": {
      "Host": "anonymousstudentreviews.database",
      "Port": 5432,
      "Database": "database",
      "Username": "username",
      "Password": "password"
    },
    "DataProtectionDatabase": {
      "Host": "anonymousstudentreviews.database",
      "Port": 5432,
      "Database": "dataprotectionkeysdb",
      "Username": "username",
      "Password": "password"
    }
  },
  "Migrations": {
    "ApplyMigrationsOnStartup": true
  },
  "AccountConfirmation": {
    "EmailVerificationTokenExpirationHours": 1,
    "SendConfirmationLetterFromAddress": "Account confirmation <auth@auth.studentus.tech>",
    "ConfirmationLetterSubject": "Верифікація пошти - Studentus"
  },
  "OpenIddict": {
    "Applications": [
      {
        "ApplicationType": "web",
        "ClientType": "Confidential",
        "ClientId": "frontend",
        "DisplayName": "frontend",
        "ConsentType": "Implicit",
        "RedirectUris": [
          "https://studentus.tech/auth/oidc/callback",
          "http://studentus.tech/auth/oidc/callback"
        ],
        "PostLogoutRedirectUris": [
          "https://studentus.tech/auth/oidc/callback",
          "http://studentus.tech/auth/oidc/callback"
        ],
        "Permissions": {
          "Endpoints": [
            "Authorization",
            "EndSession",
            "Token"
          ],
          "GrantTypes": [
            "AuthorizationCode",
            "RefreshToken"
          ],
          "Scopes": [
            "Profile",
            "Roles"
          ],
          "ResponseTypes": [
            "Token"
          ]
        },
        "Requirements": {
          "Features": [
            "ProofKeyForCodeExchange"
          ]
        }
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "https://studentus.tech"
    ]
  },
  "Login": {
    "MaxFailedAccessAttempts": 5,
    "LockoutTimeMinutes": 5
  },
  "HealthCheck": {
    "RequireHost": ""
  },
  "HeaderForwarding": {
    "KnownNetworks": [
      {
        "Prefix": "0.0.0.0",
        "PrefixLength": 0
      }
    ]
  }
}
