{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Migrations": {
    "ApplyMigrationsOnStartup": true
  },
  "Secrets": {
    "UseAws": true
  },
  "AccountConfirmation": {
    "EmailVerificationTokenExpirationHours": 1,
    "SendConfirmationLetterFromAddress": "Account confirmation <auth@auth.studentus.tech>",
    "ConfirmationLetterSubject": "Верифікація пошти - Studentus"
  },
  "OpenIddict": {
    "Applications": [
      {
        "ApplicationType": "web",
        "ClientType": "Confidential",
        "ClientId": "frontend",
        "DisplayName": "frontend",
        "ConsentType": "Implicit",
        "RedirectUris": [
          "https://studentus.tech/auth/oidc/callback"
        ],
        "PostLogoutRedirectUris": [
          "https://studentus.tech/auth/oidc/callback"
        ],
        "Permissions": {
          "Endpoints": [
            "Authorization",
            "EndSession",
            "Token"
          ],
          "GrantTypes": [
            "AuthorizationCode",
            "RefreshToken"
          ],
          "Scopes": [
            "Profile",
            "Roles"
          ],
          "ResponseTypes": [
            "Token",
            "Code"
          ]
        },
        "Requirements": {
          "Features": [
            "ProofKeyForCodeExchange"
          ]
        }
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "https://studentus.tech"
    ]
  },
  "Login": {
    "MaxFailedAccessAttempts": 5,
    "LockoutTimeMinutes": 5
  },
  "HealthCheck": {
    "RequireHost": ""
  },
  "HeaderForwarding": {
    "KnownNetworks": [
      {
        "Prefix": "127.0.0.1",
        "PrefixLength": 32
      }
    ]
  }
}
