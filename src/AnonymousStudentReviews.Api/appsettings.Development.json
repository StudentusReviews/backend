{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=anonymousstudentreviews.database;Database=database;Username=username;Password=password"
  },
  "Migrations": {
    "ApplyMigrationsOnStartup": true
  },
  "AccountConfirmation": {
    "EmailVerificationTokenExpirationHours": 1,
    "SendConfirmationLetterFromAddress": "onboarding@resend.dev",
    "ConfirmationLetterSubject": "Account confirmation"
  },
  "OpenIddict": {
    "Applications": [
      {
        "ApplicationType": "web",
        "ClientType": "Confidential",
        "ClientId": "frontend",
        "DisplayName": "frontend",
        "ConsentType": "Implicit",
        "RedirectUris": [
          "http://127.0.0.1:5500"
        ],
        "PostLogoutRedirectUris": [
          "http://127.0.0.1:5500"
        ],
        "Permissions": {
          "Endpoints:": [
            "Authorization",
            "EndSession",
            "Token"
          ],
          "GrantTypes": [
            "AuthorizationCode",
            "RefreshToken"
          ],
          "Scopes": [
            "Profile",
            "Roles"
          ],
          "ResponseTypes": [
            "Token"
          ]
        },
        "Requirements": {
          "Features": [
            "ProofKeyForCodeExchange"
          ]
        }
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "http://127.0.0.1:5500"
    ]
  },
  "Login": {
    "MaxFailedAccessAttempts": 5,
    "LockoutTimeMinutes": 5
  },
  "HealthCheck": {
    "RequireHost": ""
  }
}
